# Local development database — matches docker-compose.yml.
# Do NOT use these credentials in any non-local environment.
DATABASE_URL=postgres://disruption_intelligence:disruption_intelligence@localhost:5432/disruption_intelligence

# Sentry — optional everywhere; absent locally means Sentry stays disabled.
# Production values are injected via Fly secrets (API) / Vercel env (web),
# never committed. SENTRY_ENVIRONMENT defaults to 'development'.
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=
# VITE_SENTRY_DSN=
